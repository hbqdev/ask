# Copy to `secrets.env` (gitignored) and set the password. This file is passed
# to the container via env_file, separate from the project `.env`.
#
# REQUIRED — if MODEL_MANAGER_PASSWORD is unset the app serves 503 (fail-closed).
#
# ⚠️ IMPORTANT — escaping `$`: Docker Compose interpolates `$` in env_file
# values (e.g. `$peed` is read as a variable reference and expands to empty).
# If your password contains a `$`, write it as `$$` here. Compose turns each
# `$$` back into a single `$` at runtime, so you log in with the real password.
# Example: to use the password  G0d$peed1522!  write:
#   MODEL_MANAGER_PASSWORD=G0d$$peed1522!
# A password with no `$` needs no escaping.
MODEL_MANAGER_PASSWORD=

# Optional; the session-signing secret. Derived from the password if unset.
# (Also escape any `$` as `$$` here.)
MODEL_MANAGER_SESSION_SECRET=
