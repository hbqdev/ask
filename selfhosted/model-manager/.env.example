# The PASSWORD lives in `secrets.env`, NOT here — see secrets.env.example.
# (Docker Compose interpolates `$` in this project .env file, which would
# mangle a password containing `$`. `secrets.env` is passed to the container
# via env_file only.) MODEL_MANAGER_PASSWORD is REQUIRED — unset ⇒ 503.
MODEL_MANAGER_PORT=3939

# The Ask repo dir. It is mounted at this SAME path inside the container (see
# the compose volumes), and ASK_ENV_PATH/ASK_COMPOSE_FILE MUST live under it —
# otherwise `docker compose up -d ask` (run via the docker socket) can't resolve
# Ask's relative bind mounts on the host daemon.
ASK_REPO_DIR=/home/nightfury/selfhosted/ask
ASK_ENV_PATH=/home/nightfury/selfhosted/ask/.env
ASK_COMPOSE_FILE=/home/nightfury/selfhosted/ask/docker-compose.yaml
ASK_SERVICE=ask
MODEL_MANAGER_BACKUP_KEEP=20

# Cross-host reranker management (leave unset to disable — reranker model
# becomes read-only in the UI).
RERANKER_SSH_TARGET=
RERANKER_SSH_KEY=/keys/nightfurys
RERANKER_REMOTE_DIR=
RERANKER_ENV_FILE=.env
RERANKER_SERVICE=reranker
